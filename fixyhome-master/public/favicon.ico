<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" width="32" height="32">
  <!-- Définition des dégradés -->
  <defs>
    <linearGradient id="blueGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#3B82F6;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#8B5CF6;stop-opacity:1" />
    </linearGradient>
    <linearGradient id="purpleGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#8B5CF6;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#EC4899;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Icône maison simplifiée pour favicon -->
  <g transform="translate(2, 4)">
    <!-- Toit -->
    <path d="M14 4 L28 0 L28 8 L14 8 Z" fill="url(#blueGradient)" />
    
    <!-- Base de la maison -->
    <rect x="6" y="8" width="16" height="12" fill="url(#blueGradient)" />
    
    <!-- Porte -->
    <rect x="12" y="12" width="4" height="8" fill="#ffffff" rx="0.5" />
    
    <!-- Outil clé à molette -->
    <g transform="translate(22, 6) rotate(15)">
      <circle cx="2" cy="2" r="1.5" fill="url(#purpleGradient)" />
      <rect x="1.5" y="2" width="0.5" height="4" fill="url(#purpleGradient)" />
      <rect x="1" y="5" width="2" height="0.5" fill="url(#purpleGradient)" />
    </g>
  </g>
</svg>
