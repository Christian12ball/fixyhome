# Configuration pour l'API Spring Boot
NEXT_PUBLIC_API_URL=http://localhost:8080/api

# Configuration pour l'authentification (optionnel)
NEXT_PUBLIC_JWT_SECRET=your-jwt-secret-key

# Configuration pour la base de données (utilisé par le backend)
DATABASE_URL=postgresql://username:password@localhost:5432/fixyhome

# Configuration pour le paiement (Stripe, etc.)
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Configuration pour l'envoi d'emails
EMAIL_FROM=noreply@fixyhome.fr
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Configuration pour le stockage de fichiers (AWS S3, etc.)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=eu-west-3
AWS_S3_BUCKET=fixyhome-uploads

# Configuration pour Google Maps (géolocalisation)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Mode de développement
NODE_ENV=development
